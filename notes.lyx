\begin_layout Section
Indexes
\end_layout

\begin_layout Subsection
CCEI
\end_layout

\begin_layout Itemize
For 
\begin_inset Formula $e\in[0,1]$
\end_inset

,
 define the relaxed direct revealed relation 
\begin_inset Formula 
\[
x^{j}R^{e}x^{k}\iff p^{j}\cdot x^{k}\leq ep^{j}\cdot x^{j}
\]

\end_inset


\end_layout

\begin_layout Itemize
\begin_inset Formula $CCEI=\max\{e:\text{data satisfy GARP under }R^{e}\}$
\end_inset


\end_layout

\begin_layout Standard

\series bold
Calculation:
\end_layout

\begin_layout Itemize
Define cost ratio matrix 
\begin_inset Formula 
\[
c_{ts}=\frac{p^{t}\cdot x^{s}}{p^{t}\cdot x^{t}}
\]

\end_inset


\end_layout

\begin_layout Itemize
For candidate 
\begin_inset Formula $e$
\end_inset

:
\end_layout

\begin_deeper
\begin_layout Itemize
Draw directed edge 
\begin_inset Formula $t\rightarrow s$
\end_inset

 if 
\begin_inset Formula $c_{ts}\leq e$
\end_inset

 
\end_layout

\begin_layout Itemize
Compute transitive closure of this graph
\end_layout

\begin_layout Itemize
Check whether any revealed preference cycle violates GARP
\end_layout

\begin_layout Itemize
Search for 
\begin_inset Formula $e$
\end_inset

 by binary search or critical values of 
\begin_inset Formula $c_{ts}$
\end_inset


\end_layout

\end_deeper
\begin_layout Standard

\series bold
Loss
\end_layout

\begin_layout Itemize
\begin_inset Formula $CCEI=1$
\end_inset

 implies full rationality.
 
\begin_inset Formula $CCEI=0.95$
\end_inset

 means that the data is GARP consistent if we treat bundles costing at most 95% of the expenditure as affordable.
 I.e.
 the least budget shrinking needed for GARP to be satisfied.
\end_layout

\begin_layout Itemize
Example loss funciton for a group:
 
\begin_inset Formula 
\[
L_{CCEI}(G)=n_{G}(1-e_{G})
\]

\end_inset

or expenditure weighted: 
\begin_inset Formula 
\[
L_{CCEI}(G)=M_{G}(1-e_{G})
\]

\end_inset

where 
\begin_inset Formula $M_{G}$
\end_inset

 is the total expenditure in group 
\begin_inset Formula $G$
\end_inset

.
\end_layout

\begin_layout Subsection
Money pump index
\end_layout

\begin_layout Itemize
For a GARP-violating cycle 
\begin_inset Formula $t_{1}\rightarrow\cdots\rightarrow t_{K}$
\end_inset

 where 
\begin_inset Formula $x^{t_{\ell+1}}$
\end_inset

 was affordable when 
\begin_inset Formula $x^{t_{\ell}}$
\end_inset

 was chosen,
 the money pump cost is 
\begin_inset Formula 
\[
MP(C)=\sum_{\ell=1}^{K}p^{t_{\ell}}\cdot(x^{t_{\ell}}-x^{t_{\ell+1}})
\]

\end_inset

Since 
\begin_inset Formula $x^{t_{\ell+1}}$
\end_inset

 was affordable at 
\begin_inset Formula $p^{t_{\ell}}$
\end_inset

,
 each term is weakly positive,
 with at least one strict.
\end_layout

\begin_layout Itemize
The index is 
\begin_inset Formula 
\[
MPI(C)=\frac{\sum_{\ell=1}^{K}p^{t_{\ell}}\cdot(x^{t_{\ell}}-x^{t_{\ell+1}})}{\sum_{\ell=1}^{K}p^{t_{\ell}}\cdot x^{t_{\ell}}}
\]

\end_inset


\end_layout

\begin_layout Itemize
Add up cycles across the group?
\end_layout

\begin_layout Subsection
Afriat inequality slack loss
\end_layout

\begin_layout Itemize
Introduce weakly positive slack terms 
\begin_inset Formula 
\[
U^{s}\leq U^{t}+\lambda^{t}p^{t}\cdot[x^{s}-x^{t}]+\xi_{ts},\quad\xi_{ts}\geq0
\]

\end_inset


\end_layout

\begin_layout Itemize
Loss is 
\begin_inset Formula 
\[
L_{Afriat}(G)=\min_{U,\lambda,\xi}\sum_{t,s\in G}w_{ts}\xi_{ts}
\]

\end_inset

where 
\begin_inset Formula $w_{ts}$
\end_inset

 is the weight of the link 
\begin_inset Formula $t,s$
\end_inset

.
 Can be 
\begin_inset Formula $w_{ts}\equiv1$
\end_inset

 or weight by expenditure.
\end_layout

\begin_layout Itemize
Also need to normalize across groups since 
\begin_inset Formula $U$
\end_inset

 are arbitrary utilities:
 for example 
\begin_inset Formula 
\[
\sum_{t\in G}\lambda_{t}p^{t}\cdot x^{t}=|G|
\]

\end_inset


\end_layout

\begin_layout Standard

\series bold
Calculation:
\end_layout

\begin_layout Itemize
Compute all Afriat cost differences: 
\begin_inset Formula 
\[
a_{ts}=p^{t}\cdot(x^{s}-x^{t})
\]

\end_inset


\end_layout

\begin_layout Itemize
Solve the LP 
\begin_inset Formula 
\[
\min_{U,\lambda,\xi}\sum_{t,s}w_{ts}\xi_{ts}
\]

\end_inset

subject to 
\begin_inset Formula 
\[
U_{s}-U_{t}-\lambda_{t}a_{ts}\leq\xi_{ts}
\]

\end_inset


\begin_inset Formula 
\[
\sum_{t\in G}\lambda_{t}p^{t}\cdot x^{t}=|G|
\]

\end_inset


\end_layout

\begin_layout Standard

\series bold
Alternative:
\end_layout

\begin_layout Itemize
Can use one slack per base observation: 
\begin_inset Formula 
\[
U_{s}\leq U_{t}+\lambda_{t}p^{t}\cdot(x^{s}-x^{t})+\xi_{t}\quad\forall s,t
\]

\end_inset


\begin_inset Formula 
\[
L_{Afriat}(G)=\min_{U,\lambda,\xi}\sum_{tG}w_{t}\xi_{t}
\]

\end_inset


\end_layout

