\begin_layout Itemize

\series bold
Afriat
\series default
:
 The following are equivalent:
\end_layout

\begin_deeper
\begin_layout Itemize
Exists locally nonsatiated utility function rationalizing the data
\end_layout

\begin_layout Itemize
Data satisfies GARP
\end_layout

\begin_layout Itemize
There exist numbers 
\begin_inset Formula $\{v^{j},\lambda^{j}\}_{j}$
\end_inset

 such that 
\begin_inset Formula $U^{j}\in\mathbb{R}$
\end_inset

 and 
\begin_inset Formula $\lambda^{j}>0$
\end_inset

 with 
\begin_inset Formula 
\[
U^{s}\leq U^{t}+\lambda^{t}p^{t}\cdot[x^{s}-x^{t}]
\]

\end_inset


\end_layout

\begin_layout Itemize
I.e.
 if 
\begin_inset Formula $x^{s}$
\end_inset

 was affordable when 
\begin_inset Formula $x^{t}$
\end_inset

 was chosen,
 then 
\begin_inset Formula $p^{t}\cdot x^{s}\leq p^{t}\cdot x^{t}$
\end_inset

,
 so 
\begin_inset Formula $p^{t}\cdot(x^{s}-x^{t})\leq0$
\end_inset

.
 Then Afriat implies 
\begin_inset Formula $U^{s}\leq U^{t}$
\end_inset


\end_layout

